{
  "name": "@zwave-js/core",
  "version": "15.24.0",
  "description": "zwave-js: core components",
  "keywords": [],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "@@dev": "./src/index.ts",
      "browser": "./build/index_browser.js",
      "default": "./build/index.js"
    },
    "./bindings/*": {
      "@@dev": "./src/bindings/*.ts",
      "default": "./build/bindings/*.js"
    },
    "./safe": {
      "@@dev": "./src/index_safe.ts",
      "default": "./build/index_safe.js"
    },
    "./test": {
      "@@dev": "./src/index_test.ts",
      "default": "./build/index_test.js"
    },
    "./definitions": {
      "@@dev": "./src/definitions/index.ts",
      "default": "./build/definitions/index.js"
    },
    "./dsk": {
      "@@dev": "./src/dsk/index.ts",
      "default": "./build/dsk/index.js"
    },
    "./error": {
      "@@dev": "./src/error/ZWaveError.ts",
      "default": "./build/error/ZWaveError.js"
    },
    "./reflection": {
      "@@dev": "./src/reflection/decorators.ts",
      "default": "./build/reflection/decorators.js"
    },
    "./registries": {
      "@@dev": "./src/registries/index.ts",
      "default": "./build/registries/index.js"
    },
    "./traits": {
      "@@dev": "./src/traits/index.ts",
      "default": "./build/traits/index.js"
    },
    "./validation": {
      "@@dev": "./src/util/validation.ts",
      "default": "./build/util/validation.js"
    },
    "./qr": {
      "@@dev": "./src/qr/index.ts",
      "browser": "./build/qr/index.browser.js",
      "default": "./build/qr/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./build/reflection/decorators.js"
  ],
  "imports": {
    "#crypto_primitives": {
      "@@dev": "./src/crypto/primitives/primitives.node.ts",
      "browser": "./build/crypto/primitives/primitives.browser.js",
      "node": "./build/crypto/primitives/primitives.node.js",
      "default": "./build/crypto/primitives/primitives.browser.js"
    }
  },
  "files": [
    "build/**/*.{js,cjs,mjs,d.ts,d.cts,d.mts,map}",
    "build/**/package.json"
  ],
  "author": {
    "name": "AlCalzone",
    "email": "d.griesel@gmx.net"
  },
  "license": "MIT",
  "homepage": "https://github.com/zwave-js/zwave-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zwave-js/zwave-js.git"
  },
  "bugs": {
    "url": "https://github.com/zwave-js/zwave-js/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/AlCalzone/"
  },
  "engines": {
    "node": ">= 22.17"
  },
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --pretty",
    "clean": "del-cli build/ \"*.tsbuildinfo\"",
    "test:ts": "vitest",
    "test:dirty": "tsx ../maintenance/src/resolveDirtyTests.ts --run"
  },
  "dependencies": {
    "@alcalzone/jsonl-db": "^4.0.2",
    "@zwave-js/shared": "workspace:*",
    "alcalzone-shared": "^5.0.0",
    "ansi-colors": "^4.1.3",
    "dayjs": "^1.11.18",
    "fflate": "0.8.2",
    "logform": "^2.7.0",
    "nrf-intel-hex": "^1.4.0",
    "pathe": "^2.0.3",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.2",
    "triple-beam": "*",
    "tslib": "^2.8.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^21.0.0",
    "@types/triple-beam": "^1.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "del-cli": "^7.0.0",
    "sinon": "^21.0.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
