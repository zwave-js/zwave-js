{
  "name": "@zwave-js/cc",
  "version": "15.23.5",
  "description": "zwave-js: Command Classes",
  "keywords": [],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "@@dev": "./src/index.ts",
      "browser": "./build/esm/index_browser.js",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    },
    "./safe": {
      "@@dev": "./src/index_safe.ts",
      "import": "./build/esm/index_safe.js",
      "require": "./build/cjs/index_safe.js"
    },
    "./cc": {
      "@@dev": "./src/cc/index.ts",
      "import": "./build/esm/cc/index.js",
      "require": "./build/cjs/cc/index.js"
    },
    "./package.json": "./package.json",
    "./*": {
      "@@dev": "./src/cc/*.ts",
      "import": "./build/esm/cc/*.js",
      "require": "./build/cjs/cc/*.js"
    }
  },
  "files": [
    "build/**/*.{js,cjs,mjs,d.ts,d.cts,d.mts,map}",
    "build/**/package.json"
  ],
  "sideEffects": false,
  "author": {
    "name": "AlCalzone",
    "email": "d.griesel@gmx.net"
  },
  "license": "MIT",
  "homepage": "https://github.com/zwave-js/zwave-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zwave-js/zwave-js.git"
  },
  "bugs": {
    "url": "https://github.com/zwave-js/zwave-js/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/AlCalzone/"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "task": "yarn ts maintenance/_tasks.ts",
    "codegen": "yarn task codegen && yarn lint:codegen:fix",
    "build": "tsgo -b tsconfig.build.json --pretty && yarn postbuild",
    "postbuild": "yarn esm2cjs --in build/esm --out build/cjs -l error -t node20",
    "clean": "del-cli build/ src_gen/ \"*.tsbuildinfo\"",
    "extract-api": "yarn api-extractor run",
    "ts": "tsx --conditions=@@dev",
    "lint:codegen:fix": "oxlint --type-aware -c ../../.oxlintrc.json --fix \"src/cc/_CCValues.generated.ts\" \"src/lib/_CCAPI.generated.ts\"",
    "test:ts": "vitest",
    "test:dirty": "tsx ../maintenance/src/resolveDirtyTests.ts --run"
  },
  "dependencies": {
    "@zwave-js/core": "workspace:*",
    "@zwave-js/host": "workspace:*",
    "@zwave-js/shared": "workspace:*",
    "alcalzone-shared": "^5.0.0",
    "ansi-colors": "^4.1.3",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@alcalzone/esm2cjs": "^1.4.2",
    "@microsoft/api-extractor": "^7.57.7",
    "@types/node": "^20.19.35",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "@zwave-js/maintenance": "workspace:*",
    "@zwave-js/transformers": "workspace:*",
    "del-cli": "^7.0.0",
    "es-main": "^1.4.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
