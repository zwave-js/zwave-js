	"compat": {
		// The device has a Multilevel sensor on endpoint 2 which is not mirrored on the
		// root endpoint. However, the endpoints are considered unnecessary, so endpoint 2
		// gets hidden along with the sensor.
		"preserveEndpoints": [2],
		"preserveRootApplicationCCValueIDs": true,

		// The device is a Binary Sensor, but uses Basic Sets to report its status
		"mapBasicSet": "auto"
	},
	"metadata": {
		"inclusion": "Quickly, three times press the TMP button.",
		"exclusion": "Quickly, three times press the TMP button.",
		"reset": "1. Take off the sensor's cover and remove the battery.\n2. Touch the sensor's body with a magnet.\n3. Insert the battery.\n4. Within 2 seconds, remove the magnet from the sensor's body. The LED will turn off.\n5. Wait 3 seconds until the LED starts blinking, then remove the battery.",
		"manual": "https://manuals.fibaro.com/content/manuals/en/FGK-10x/FGK-10x-EN-A-v1.01.pdf"
