{
  "name": "zwave-js",
  "version": "15.24.0",
  "description": "Z-Wave driver written entirely in JavaScript/TypeScript",
  "keywords": [],
  "type": "module",
  "exports": {
    ".": {
      "@@dev": "./src/index.ts",
      "browser": "./build/index_browser.js",
      "default": "./build/index.js"
    },
    "./safe": {
      "@@dev": "./src/index_safe.ts",
      "default": "./build/index_safe.js"
    },
    "./Controller": {
      "@@dev": "./src/Controller.ts",
      "default": "./build/Controller.js"
    },
    "./Driver": {
      "@@dev": "./src/Driver.ts",
      "default": "./build/Driver.js"
    },
    "./Error": {
      "@@dev": "./src/Error.ts",
      "default": "./build/Error.js"
    },
    "./Node": {
      "@@dev": "./src/Node.ts",
      "default": "./build/Node.js"
    },
    "./Testing": {
      "@@dev": "./src/Testing.ts",
      "default": "./build/Testing.js"
    },
    "./Utils": {
      "@@dev": "./src/Utils.ts",
      "default": "./build/Utils.js"
    },
    "./Values": {
      "@@dev": "./src/Values.ts",
      "default": "./build/Values.js"
    },
    "./Zniffer": {
      "@@dev": "./src/Zniffer.ts",
      "default": "./build/Zniffer.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#default_bindings/fs": {
      "@@dev": "@zwave-js/core/bindings/fs/node",
      "node": "@zwave-js/core/bindings/fs/node",
      "default": "@zwave-js/core/bindings/fs/stub"
    },
    "#default_bindings/serial": {
      "@@dev": "@zwave-js/serial/bindings/node",
      "node": "@zwave-js/serial/bindings/node",
      "default": "@zwave-js/serial/bindings/stub"
    },
    "#default_bindings/db": {
      "@@dev": "@zwave-js/core/bindings/db/jsonl",
      "node": "@zwave-js/core/bindings/db/jsonl",
      "default": "@zwave-js/core/bindings/db/stub"
    },
    "#default_bindings/log": {
      "@@dev": "@zwave-js/core/bindings/log/node",
      "node": "@zwave-js/core/bindings/log/node",
      "default": "@zwave-js/core/bindings/log/stub"
    },
    "#mdns_discovery": {
      "@@dev": "./src/lib/driver/mDNSDiscovery/node.ts",
      "node": "./build/lib/driver/mDNSDiscovery/node.js",
      "default": "./build/lib/driver/mDNSDiscovery/stub.js"
    }
  },
  "files": [
    "bin/",
    "build/**/*.{js,cjs,mjs,d.ts,d.cts,d.mts,map}",
    "build/**/package.json"
  ],
  "sideEffects": false,
  "bin": {
    "mock-server": "bin/mock-server.mjs"
  },
  "author": {
    "name": "AlCalzone",
    "email": "d.griesel@gmx.net"
  },
  "license": "MIT",
  "homepage": "https://github.com/zwave-js/zwave-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zwave-js/zwave-js.git"
  },
  "bugs": {
    "url": "https://github.com/zwave-js/zwave-js/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/AlCalzone/"
  },
  "engines": {
    "node": ">= 22.12"
  },
  "scripts": {
    "ts": "tsx --conditions=@@dev",
    "codegen": "yarn ts maintenance/codegen.ts",
    "build": "tsgo -b tsconfig.build.json --pretty",
    "watch": "tsgo -b tsconfig.build.json --pretty --watch",
    "clean": "del-cli build/ \"*.tsbuildinfo\"",
    "extract-api": "yarn api-extractor run",
    "test:ts": "vitest",
    "test:dirty": "tsx ../maintenance/src/resolveDirtyTests.ts --run"
  },
  "dependencies": {
    "@alcalzone/jsonl-db": "^4.0.2",
    "@andrewbranch/untar.js": "^1.0.3",
    "@homebridge/ciao": "^1.3.5",
    "@zwave-js/cc": "workspace:*",
    "@zwave-js/config": "workspace:*",
    "@zwave-js/core": "workspace:*",
    "@zwave-js/host": "workspace:*",
    "@zwave-js/nvmedit": "workspace:*",
    "@zwave-js/serial": "workspace:*",
    "@zwave-js/shared": "workspace:*",
    "@zwave-js/testing": "workspace:*",
    "@zwave-js/waddle": "^1.2.1",
    "alcalzone-shared": "^5.0.0",
    "ansi-colors": "^4.1.3",
    "ky": "^1.8.1",
    "mdns-server": "^1.0.11",
    "p-queue": "^9.1.0",
    "pathe": "^2.0.3",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.7.2",
    "serialport": "^13.0.0",
    "source-map-support": "^0.5.21",
    "tslib": "^2.8.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.7",
    "@types/node": "^20.19.35",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^21.0.0",
    "@types/source-map-support": "^0.5.10",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "@zwave-js/maintenance": "workspace:*",
    "del-cli": "^7.0.0",
    "mockdate": "^3.0.5",
    "sinon": "^21.0.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
